# ============================================
# Required Configuration
# ============================================

# Hive username whose posts will be displayed on the blog
HIVE_USERNAME=your-hive-username

# ============================================
# Optional Configuration
# ============================================

# Custom Hive API endpoint (defaults to https://api.openhive.network)
# PUBLIC_HIVE_API_ENDPOINT=https://api.hive.blog

# Hive chain ID (defaults to mainnet beeab0de..., set to 42 for mirrornet)
# PUBLIC_HIVE_CHAIN_ID=42

# Hive images proxy endpoint (defaults to https://images.hive.blog)
# PUBLIC_HIVE_IMAGES_ENDPOINT=https://images.hive.blog

# Hive blog base URL for profile/post links (defaults to https://blog.openhive.network)
# PUBLIC_HIVE_BLOG_URL=https://blog.openhive.network

# Config storage location on Hive blockchain (defaults to @barddev/my-blog-configs)
# CONFIG_PARENT_AUTHOR=barddev
# CONFIG_PARENT_PERMLINK=my-blog-configs

# Site URL for canonical links and SEO (used by Astro site config)
# PUBLIC_SITE_URL=https://your-domain.com

# ============================================
# Docker Deployment Configuration
# ============================================

# Domain for Traefik reverse proxy (required for Docker deployment)
# DOMAIN=yourdomain.com

# ============================================
# Testing Configuration (E2E Tests)
# ============================================

# Hive credentials for Playwright E2E tests
# TEST_HIVE_USERNAME=testuser
# TEST_HIVE_PASSWORD=testpassword
# TEST_HIVE_WIF=
